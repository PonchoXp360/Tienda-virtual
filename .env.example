# ═══════════════════════════════════════════════════════════════
# ChAcHaRiTaS — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a GitHub.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL / Supabase / Neon)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:password@localhost:5432/tienda_virtual"
# Ejemplo Supabase:  postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Ejemplo Neon:      postgresql://[user]:[pass]@[host].neon.tech/[dbname]?sslmode=require

# ─────────────────────────────────────────────
# AUTENTICACIÓN — Better Auth
# ─────────────────────────────────────────────
# Genera el secreto con: openssl rand -base64 32
BETTER_AUTH_SECRET="genera_un_secreto_aleatorio_de_32_chars_minimo"
BETTER_AUTH_URL="https://tudominio.com"           # URL pública de la app (sin / al final)
NEXT_PUBLIC_APP_URL="https://tudominio.com"        # Mismo valor, accesible en el cliente

# OAuth Google (opcional — para botón "Continuar con Google")
# Crear en: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# PAGOS — Stripe
# ─────────────────────────────────────────────
# Claves en: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Secreto del Webhook (generado al crear el endpoint en Stripe)
# Test local:  stripe listen --forward-to localhost:9002/api/stripe/webhook
# Producción:  dashboard.stripe.com/webhooks → Añadir endpoint
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────
# IA — Google Genkit / Gemini
# ─────────────────────────────────────────────
# Obtener en: aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=""

# ─────────────────────────────────────────────
# EMAIL — Resend (opcional — para emails transaccionales)
# ─────────────────────────────────────────────
# Crear en: resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@tudominio.com"
